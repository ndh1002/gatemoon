# Database
DATABASE_URL=postgresql://moonhunter:moonhunter@postgres:5432/moonhunter

# Redis
REDIS_URL=redis://redis:6379/0

# Gate.io (optional: public endpoints work without keys; keys raise rate limits)
GATE_API_KEY=
GATE_API_SECRET=

# Scanner
SCAN_INTERVAL_SECONDS=12
TOP_SYMBOLS_BY_QUOTE_VOLUME=80
MIN_QUOTE_VOLUME_USDT=500000

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_MOONSHOT_SCORE=72
TELEGRAM_MAX_RISK_SCORE=45
TELEGRAM_COOLDOWN_MINUTES=30

# Social / meme (optional — improves social_velocity when set)
TWITTER_BEARER_TOKEN=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000
